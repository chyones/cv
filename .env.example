# Google service account with Editor access to the target Drive folder
# (create in Google Cloud Console > IAM & Admin > Service Accounts, then
# share the Drive folder below with its email as Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key from the service account's JSON key.
# Keep the literal \n line-break sequences if pasting as a single line.
GOOGLE_PRIVATE_KEY=

# Target Google Drive folder ID (from the folder's URL).
GOOGLE_DRIVE_FOLDER_ID=1bDjbuIAjneyY-y0D1o5EGtOvkc_TaKIn

# Maximum accepted CV size, in megabytes.
MAX_CV_SIZE_MB=50
