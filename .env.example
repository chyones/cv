# Google OAuth 2.0 user credentials, authorized once against the personal
# Google account that owns the target Drive folder ("My Drive > Staff
# Updated CVs"). Uploaded files are owned by that account.
#
# 1. Google Cloud Console > APIs & Services > Credentials > Create
#    Credentials > OAuth client ID > Application type: Desktop app.
# 2. Paste its Client ID / Client secret below.
# 3. Run `node scripts/get-refresh-token.mjs` (see that file's header) to
#    fill in GOOGLE_OAUTH_REFRESH_TOKEN. Never paste that token anywhere
#    else -- the script writes it directly into this file.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Target Google Drive folder ID (from the folder's URL).
GOOGLE_DRIVE_FOLDER_ID=1bDjbuIAjneyY-y0D1o5EGtOvkc_TaKIn

# Maximum accepted CV size, in megabytes.
MAX_CV_SIZE_MB=50
